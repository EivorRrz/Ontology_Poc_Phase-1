# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
# Set MONGODB_USE_LOCAL=true when Atlas is unreachable (network/firewall). Requires local MongoDB (e.g. docker run -d -p 27017:27017 mongo)
# MONGODB_USE_LOCAL=false
MONGODB_URI=mongodb://localhost:27017/document-graph-pipeline
# Optional: retries and delay if Atlas is slow (default: 2 retries, 3s delay)
# MONGODB_CONNECT_RETRIES=2
# MONGODB_CONNECT_RETRY_DELAY_MS=3000

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-password-here

# LlamaParse Configuration (optional)
LLAMAPARSE_API_KEY=your-llamaparse-api-key

# Azure OpenAI (Full Ontology - aligned with Agent-02)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Chunking Configuration
CHUNK_SIZE_WORDS=1000
CHUNK_OVERLAP_WORDS=100

# Logging
LOG_LEVEL=info
